@charset "utf-8";

.logo-container { display: block; position: absolute; right: 0px; bottom: 0=
px; z-index: 65534; font-size: 0px; height: 16px; padding: 0px 1px; backgro=
und: rgba(0, 0, 0, 0.3); opacity: 0.5; }

.logo-container a { font-size: 0px; background: rgba(102, 102, 102, 0.6); }

.logo-container a img { position: static; border: 0px; }

.logo-container .gap { display: inline-block; width: 1px; height: 16px; bac=
kground-color: rgb(255, 255, 255); opacity: 0.45; }

.logo-link { display: inline-block; width: 33px; height: 10px; margin: 3px =
4px; }

.logo-close-img { display: inline-block; width: 8px; height: 8px; margin: 4=
px; }

.logo-mobile-container .logo-link { width: 33px; margin: 3px 4px; }

.feedback-container { display: none; position: absolute; z-index: 65535; in=
set: 0px; height: 100%; background: rgb(252, 252, 252); font-size: 12px; co=
lor: rgb(102, 102, 102); }

.feedback-container a { font-size: 12px; }

.feedback-container .intro { font-size: 14px; }

.feedback-container .bk-logo { position: absolute; z-index: -1; right: 10px=
; bottom: 10px; width: 68px; height: 22px; background: url("../images/logo-=
fb-big.png"); }

.feedback-container.fd-small .bk-logo { right: 5px; bottom: 5px; width: 50p=
x; height: 16px; background: url("../images/logo-fb-small.png"); }

.feedback-container.fd-small .closed-content { padding: 5px; font-size: 14p=
x; font-weight: 400; }

.reason-content { margin: 0px auto; }

.reason-item { display: inline-block; width: 48px; border: 1px solid rgb(21=
9, 219, 219); line-height: 2; text-align: center; padding: 0px 10px; margin=
: 5px 10px 0px 0px; text-decoration: none; color: rgb(102, 102, 102); }

.reason-item:hover { background-color: rgb(238, 238, 238); }

.fb-btn-cancel { display: block; margin-top: 10px; text-decoration: none; c=
olor: rgb(51, 137, 227); }

.thx-content { display: none; margin-top: 10px; text-align: center; }

.thx-content h5 { font-size: 16px; margin: 0px; }

.thx-content p { margin-top: 5px; font-size: 12px; text-align: center; }

.closed-content { display: none; padding: 20px 0px 0px 20px; font-size: 16p=
x; font-weight: 700; }
