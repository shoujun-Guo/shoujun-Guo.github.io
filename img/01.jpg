------MultipartBoundary--7zVaoJQoLZWXh7EHT8BJiMPSdblwddbjdfVmEQo34V----
Content-Type: text/css
Content-Transfer-Encoding: quoted-printable
Content-Location: https://icon.zol-img.com.cn/group/css/zLoginDialog.css

@charset "gbk";

body, h1, h2, h3, h4, h5, h6, dl, dt, dd, ul, ol, li, th, td, p, blockquote=
, pre, form, fieldset, legend, input, button, textarea, hr { margin: 0px; p=
adding: 0px; }

.login-dialog, input { font: 12px / 1.5 Arial; color: rgb(51, 51, 51); }

select, input, button { vertical-align: middle; font-size: 100%; }

ul, ol { list-style: none; }

fieldset, img { border: 0px; }

em { font-style: normal; }

.clear { clear: both; }

.clearfix::after { content: "."; display: block; visibility: hidden; clear:=
 both; height: 0px; font-size: 0px; }

.clearfix { }

input::-webkit-search-cancel-button { display: none; }

.login-dialog a { color: rgb(7, 81, 154); text-decoration: none; }

.login-dialog a:hover { color: rgb(204, 0, 0); text-decoration: underline; =
}

.login-social-btn i, .login-dialog-close, .login-input-item .ico, .login-bt=
n-wait .pass-btn, .login-input-item .delete-btn, .login-input-itembox .logi=
n-right-ico, .login-wrong-tips .login-wrong-ico, .login-warning-tips .login=
-warning-ico, .login-dialog-header h3 { background: url("//icon.zol-img.com=
.cn/login/login2014/icos.png") no-repeat; }

#J_LoginOverlay { z-index: 10000; position: fixed; top: 0px; left: 0px; wid=
th: 100%; height: 100%; }

#J_LoginOverlay .login-dialog-overlay { position: absolute; left: 0px; top:=
 0px; z-index: 2; width: 100%; height: 100%; background: rgb(0, 0, 0); opac=
ity: 0.4; }

#J_LoginOverlay iframe { position: absolute; left: 0px; top: 0px; width: 10=
0%; height: 100%; background: rgb(0, 0, 0); opacity: 0; border: 0px none; }

.login-dialog { padding: 5px; background: rgba(0, 0, 0, 0.3); }

.login-dialog-inner { background: rgb(255, 255, 255); }

.login-dialog-close { position: absolute; right: 12px; top: 17px; width: 17=
px; height: 17px; background-position: -316px 3px; text-indent: -9999em; ov=
erflow: hidden; cursor: pointer; }

.login-dialog-close:hover { background-color: rgb(179, 179, 179); backgroun=
d-position: -332px 3px; }

.login-dialog-header { height: 30px; padding: 4px 10px; background-color: r=
gb(250, 250, 250); border-bottom: 1px solid rgb(238, 238, 238); }

.login-dialog-header h3 { padding: 0px; font: 16px / 30px "Microsoft YaHei"=
, arial; background: none; }

.login-zol { width: 300px; margin: 0px auto; padding: 15px 0px 30px; }

.pass-btn { display: block; width: 300px; height: 42px; background-color: r=
gb(0, 142, 245); border: 0px none; line-height: 42px; font-size: 16px; font=
-weight: 700; outline: none; text-align: center; color: rgb(255, 255, 255);=
 cursor: pointer; }

.pass-btn:hover { background-color: rgb(0, 132, 228); color: rgb(255, 255, =
255); text-decoration: none; }

.login-btn { position: relative; zoom: 1; height: 42px; }

.login-btn .wait-bar { display: none; position: absolute; top: 38px; left: =
0px; height: 4px; background: url("//icon.zol-img.com.cn/login/login2014/lo=
gin-bar.png") 100% center no-repeat rgb(91, 201, 46); font: 0px / 0 arial; =
}

.login-btn-wait .pass-btn { background-color: rgb(0, 142, 245); color: rgb(=
163, 204, 250); overflow: hidden; text-indent: -999em; background-position:=
 0px -248px; cursor: default; }

.login-btn-wait .wait-bar { display: block; }

.login-social { width: 298px; height: 86px; padding: 0px 10px 22px; margin:=
 34px auto 0px; border-bottom: 1px dashed rgb(230, 230, 230); }

.login-social .login-social-btn { float: left; width: 58px; height: 86px; m=
argin: 0px 21px 0px 0px; text-align: center; line-height: 18px; color: rgb(=
102, 102, 102); overflow: hidden; }

.login-social-btn i { display: block; width: 58px; height: 58px; margin: 0p=
x 0px 10px; }

.qq-btn i { background-position: 0px 0px; }

.sina-btn i { background-position: 0px -186px; }

.weixin-btn i { background-position: 0px -124px; }

.baidu-btn i { background-position: 0px -62px; }

.login-social .baidu-btn { margin: 0px; }

.qq-btn:hover i { background-position: -68px 0px; }

.sina-btn:hover i { background-position: -68px -186px; }

.weixin-btn:hover i { background-position: -68px -124px; }

.baidu-btn:hover i { background-position: -68px -62px; }

.login-social-btn:hover { color: rgb(204, 0, 0); }

.login-social-btn:hover i { cursor: pointer; }

.login-regist { float: left; width: 300px; padding: 0px 94px; }

.login-box { width: 300px; background-color: rgb(255, 255, 255); }

.login-wrong-tips, .login-warning-tips { width: 288px; height: 26px; margin=
: 10px 0px 0px; padding: 0px 5px; background-color: rgb(254, 242, 239); bor=
der: 1px solid rgb(252, 213, 212); color: rgb(102, 102, 102); line-height: =
26px; }

.login-wrong-tips .login-wrong-ico, .login-wrong-tips .login-warning-ico { =
display: inline-block; width: 18px; height: 26px; margin: 0px 6px 0px 0px; =
vertical-align: top; background-position: -355px -110px; }

.login-warning-tips { background-color: rgb(230, 244, 254); border-color: r=
gb(187, 224, 252); }

.login-warning-tips .login-warning-ico { background-position: -355px -142px=
; }

.login-member-pass { margin: 0px 0px 17px; color: rgb(102, 102, 102); }

.login-member-pass .login-zol-forget-register { float: right; color: rgb(20=
4, 204, 204); }

.login-member-pass .autologon { margin-left: 5px; }

.pass-reglink { margin: 7px 0px 0px; text-align: right; color: rgb(102, 102=
, 102); }

.login-input-itembox { position: relative; width: 300px; padding: 10px 0px;=
 }

.login-input-itembox .login-right-ico { position: absolute; top: 21px; righ=
t: -29px; width: 18px; height: 18px; background-position: -262px 0px; displ=
ay: none; }

.login-input-item { position: relative; width: 236px; height: 22px; padding=
: 7px 27px 7px 35px; border: 1px solid rgb(230, 230, 230); }

.login-input-item .login-txt { position: relative; z-index: 1; width: 215px=
; height: 18px; padding: 2px 0px 2px 10px; border-width: 0px 0px 0px 1px; b=
order-style: none none none solid; border-top-color: initial; border-right-=
color: initial; border-bottom-color: initial; border-image: initial; border=
-left-color: rgb(230, 230, 230); background-color: transparent; outline: no=
ne; color: rgb(102, 102, 102); font-size: 16px; line-height: 18px; }

.login-input-item .ico { position: absolute; }

.login-user-name .ico { top: 8px; left: 9px; width: 17px; height: 18px; bac=
kground-position: -356px 0px; }

.login-user-pwd .ico { top: 8px; left: 10px; width: 15px; height: 19px; bac=
kground-position: -358px -56px; }

.login-input-item .delete-btn { position: absolute; top: 8px; right: 6px; w=
idth: 22px; height: 21px; cursor: pointer; background-position: -297px 5px;=
 }

.login-input-item .delete-btn:hover { background-position: -280px 5px; }

.login-input-item .txt-tip { position: absolute; top: 7px; left: 46px; z-in=
dex: 0; font-size: 14px; line-height: 20px; color: rgb(204, 204, 204); }

.login-item-focus { border-color: rgb(7, 145, 245); }

.login-item-wrong { border-color: rgb(252, 67, 67); }

.login-user-name { z-index: 2; }

.login-user-name .login-item-focus .ico { background-position: -356px -28px=
; }

.login-user-pwd .login-item-focus .ico { background-position: -358px -85px;=
 }

.login-input-item .item-tippop { position: absolute; top: 37px; left: -1px;=
 width: 298px; padding: 3px 0px; border: 1px solid rgb(231, 231, 231); back=
ground-color: rgb(255, 255, 255); }

.login-input-item .item-tippop li { padding: 6px 27px 6px 46px; font-size: =
16px; color: rgb(102, 102, 102); line-height: 18px; cursor: pointer; white-=
space: normal; word-break: break-all; overflow-wrap: break-word; }

.login-input-item .item-tippop li:hover, .login-input-item .item-tippop li.=
tippopHover { background-color: rgb(246, 246, 246); }

.pass-verifycode .login-input-item { width: 88px; padding-left: 0px; paddin=
g-right: 30px; }

.pass-verifycode .login-input-item .txt-tip { left: 10px; }

