@charset "utf-8";

.pic_itemColumnSpace { height: 40px; float: left; margin-top: 0px; margin-b=
ottom: 0px; width: 4px; }

.pic_item { float: left; overflow: hidden; width: 143px; height: 118px; pos=
ition: relative; }

.pic { text-align: center; margin: 0px; border: 1px solid rgb(221, 221, 221=
); height: 100px; overflow: hidden; }

.pic .img { width: 141px; height: 100px; }

.pic_title { margin: 0px auto; padding: 0px; overflow: hidden; text-align: =
center; text-decoration: none; width: 141px; height: 16px; line-height: 16p=
x; font-family: =E5=AE=8B=E4=BD=93; font-size: 12px; font-weight: normal; }

.pic_container .title_on_pic { color: rgb(255, 255, 255); position: absolut=
e; top: 81px; left: 1px; height: 20px; line-height: 20px; }

.pic_container .title_under_pic { color: rgb(0, 0, 0); }

.title_on_pic_bg { background-color: rgb(0, 0, 0); opacity: 0.7; height: 20=
px; }

.mask { position: absolute; top: 1px; left: 1px; height: 100px; width: 141p=
x; display: none; }

.mask_head { color: rgb(255, 255, 255); text-align: left; display: inline-b=
lock; padding: 2px 4px; font-size: 12px; }

.mask_title { color: rgb(255, 255, 255); padding: 3px 5px; border: 1px soli=
d rgb(255, 255, 255); display: inline-block; width: 121px; font-size: 14px;=
 overflow: hidden; max-height: 32px; line-height: 16px; }

.hover .pic { border: 1px solid rgb(244, 0, 0); }

.hover .title_under_pic { color: rgb(244, 0, 0); }

.hover .title_on_pic { color: rgb(244, 0, 0); }

.hover .pic img { transition: transform 0.5s ease-in 0s; transform: scale(1=
.2); }

.pic_item_hover .mask { display: block; }

.pic_item_hover .pic_title a { color: rgb(255, 255, 255); font-weight: 900;=
 }

.pic_item_hover .title_on_pic_bg { display: none; }

.pic_item_hover .title_on_pic { top: -161px; font-size: 16px; font-weight: =
900; }

.img_blur { filter: blur(4px); }

.flagShow { position: absolute; top: 1px; left: 1px; width: 25px; height: 2=
5px; overflow: hidden; }

.angle { width: 0px; height: 0px; border-top: 25px solid rgb(211, 211, 211)=
; border-right: 25px solid transparent; }

.number { top: 1px; left: 2px; position: absolute; color: rgb(255, 255, 255=
); }

.triangle_0 { border-top-color: rgb(216, 30, 6) !important; }

.triangle_1 { border-top-color: rgb(218, 67, 58) !important; }

.triangle_2 { border-top-color: rgb(216, 76, 6) !important; }
